# ── Core (required) ───────────────────────────────────────────────
REDIS_URL=redis://user:pass@host:6379
GITHUB_PAT=ghp_your_token_here
GITHUB_OWNER=dev-tyta
GITHUB_REPO=dev-tyta.github.io
POSTS_PATH=data/posts.json
ALLOWED_ORIGIN=https://dev-tyta.github.io

# ── Agent LLMs (at least one required) ───────────────────────────
GOOGLE_API_KEY=your_gemini_api_key       # primary — Gemini 1.5 Flash
GROQ_API_KEY=your_groq_api_key           # fallback — llama-3.1-8b-instant (free)

# ── Agent LLM tuning (optional) ──────────────────────────────────
GEMINI_MODEL=gemini-1.5-flash
GROQ_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024
AGENT_MAX_ITERATIONS=6
SESSION_TTL_SECONDS=86400               # 24 hours

# ── Web search (optional — DDG used as free fallback) ────────────
TAVILY_API_KEY=your_tavily_api_key

# ── Email contact (optional) ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com          # use a Gmail App Password
SMTP_PASSWORD=your_app_password
CONTACT_EMAIL=hardeykoryar7@gmail.com

# ── Observability (optional) ──────────────────────────────────────
LANGCHAIN_API_KEY=your_langsmith_key    # enables LangSmith tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=testimony-portfolio-agent
LOG_LEVEL=INFO

# ── GitHub token for agent's GitHub tool (optional) ───────────────
GITHUB_TOKEN=ghp_token_for_higher_rate_limit
